<Window x:Class="WindowsAuthApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsAuthApp"
        mc:Ignorable="d"
        Title="Приложение с Windows-аутентификацией" 
        Height="1080" Width="1920"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="200"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="10">
            <TextBlock Text="Аутентификация Windows" 
                      Foreground="White" 
                      FontSize="20" 
                      FontWeight="Bold"
                      HorizontalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="#F0F0F0" 
                    Padding="15" 
                    CornerRadius="5"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Текущий пользователь Windows:" 
                              FontWeight="Bold" 
                              FontSize="14"/>
                    <TextBlock x:Name="CurrentUserText" 
                              Text="Не определено" 
                              FontSize="12"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,10">
                <TextBlock Text="Аутентификация" 
                          FontWeight="Bold" 
                          FontSize="16"/>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                              Text="Домен:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             x:Name="DomainTextBox" 
                             Text=""/>

                    <TextBlock Grid.Row="1" Grid.Column="0" 
                              Text="Имя пользователя:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" 
                             x:Name="UsernameTextBox" 
                             Text=""/>

                    <TextBlock Grid.Row="2" Grid.Column="0" 
                              Text="Пароль:"/>
                    <PasswordBox Grid.Row="2" Grid.Column="1" 
                                x:Name="PasswordBox" 
                                Margin="5"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Center"
                       Margin="0,20">
                <Button x:Name="LoginButton" 
                       Content="Войти" 
                       Click="LoginButton_Click"
                       Background="#007ACC"
                       Foreground="White"/>

                <Button x:Name="WindowsLoginButton" 
                       Content="Войти как текущий пользователь" 
                       Click="WindowsLoginButton_Click"
                       Background="#68217A"
                       Foreground="White"/>

                <Button x:Name="CheckAdminButton" 
                       Content="Проверить права администратора" 
                       Click="CheckAdminButton_Click"/>
            </StackPanel>

            <Border Grid.Row="3" 
                    Background="#FFF4F4" 
                    Padding="15" 
                    CornerRadius="5"
                    Margin="0,20,0,10"
                    BorderBrush="#FF6B6B"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Результат аутентификации:" 
                              FontWeight="Bold"/>
                    <TextBlock x:Name="AuthResultText" 
                              Text="Ожидание входа..."
                              TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" 
                    Background="#F5F5F5" 
                    Padding="15" 
                    CornerRadius="5">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="Детальная информация:" 
                                  FontWeight="Bold" 
                                  Margin="0,0,0,10"/>
                        <TextBlock x:Name="UserDetailsText" 
                                  Text="Информация будет отображена после аутентификации"
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="5" 
                    Background="#E8E8E8" 
                    Padding="10" 
                    CornerRadius="5"
                    Margin="0,10,0,0"
                    MaxHeight="100">
                <StackPanel>
                    <TextBlock Text="Журнал событий:" 
                              FontWeight="Bold"/>
                    <ListBox x:Name="LogListBox" 
                            Height="60"
                            Background="White"
                            BorderThickness="1"
                            BorderBrush="#CCCCCC">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                          FontSize="10"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="2" Background="#007ACC">
            <StatusBarItem>
                <TextBlock Foreground="White" 
                          x:Name="StatusBarText" 
                          Text="Готово"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Foreground="White" 
                          Text="{Binding CurrentDateTime, StringFormat='Дата и время: {0:dd.MM.yyyy HH:mm:ss}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>